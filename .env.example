# Alpaca Paper Trading — get keys at alpaca.markets → API → Generate New Keys
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET=your_secret_key_here

# "paper" = no real money, "live" = real money
MODE=paper

# Trading pair and timeframe
SYMBOL=BTC/USD
TIMEFRAME=1h

# Risk: % of portfolio per trade (0.02 = 2%)
RISK_PER_TRADE=0.02
